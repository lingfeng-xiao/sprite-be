{"type":"message","id":"eb4c08ab","parentId":"f7dcf1a5","timestamp":"2026-03-18T12:45:05.596Z","message":{"role":"user","content":[{"type":"text","text":"[cron:58b564ba-7837-434a-9d8e-632542b6443d 小艺感知心跳 - 每15分钟] 请执行 perception.py 脚本并输出感知报告。脚本路径: C:\\Users\\16343\\.openclaw\\agents\\xiao-yi\\workspace\\perception.py\nCurrent time: Wednesday, March 18th, 2026 — 20:45 (Asia/Shanghai) / 2026-03-18 12:45 UTC\n\nReturn your summary as plain text; it will be delivered automatically. If the task explicitly calls for messaging a specific external recipient, note who/where it should go instead of sending it yourself."}],"timestamp":1773837905595}}
{"type":"message","id":"6ca98e14","parentId":"eb4c08ab","timestamp":"2026-03-18T12:45:10.257Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"用户要求我执行 perception.py 脚本并输出感知报告。这是一个定时任务（cron job），我需要执行这个脚本来生成心跳报告。\n\n让我先读取这个脚本看看它做什么，然后执行它。","thinkingSignature":"267dabf3469c34ed0d4e4206acddd443a4a198f5b39aafdba3002f3c7e20d3ad"},{"type":"toolCall","id":"call_function_hs8hkyslnv2f_1","name":"read","arguments":{"file_path":"C:\\Users\\16343\\.openclaw\\agents\\xiao-yi\\workspace\\perception.py"}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":60,"output":88,"cacheRead":25498,"cacheWrite":10918,"totalTokens":36564,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773837905596}}
{"type":"message","id":"92ab92fb","parentId":"6ca98e14","timestamp":"2026-03-18T12:45:10.265Z","message":{"role":"toolResult","toolCallId":"call_function_hs8hkyslnv2f_1","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\n🧚 电脑精灵感知系统 - 完整版 v2\n包含美学感知 + 自主进化\n\"\"\"\nimport sys\nimport io\nsys.stdout = io.TextIOWrapper(sys.stdout.buffer, encoding='utf-8')\n\nimport json\nimport os\nimport time\nfrom datetime import datetime\nfrom pathlib import Path\nimport subprocess\n\n# ========== 配置 ==========\nPERCEPTION_DIR = Path(os.environ.get('WORKSPACE', '.')) / 'perception_data'\nPERCEPTION_DIR.mkdir(exist_ok=True)\n\n# ========== 1. 感知自己 ==========\ndef perceive_self():\n    return {\n        \"timestamp\": datetime.now().isoformat(),\n        \"status\": \"active\",\n        \"identity\": \"小艺 - 电脑精灵\"\n    }\n\n# ========== 2. 感知环境 ==========\ndef perceive_hardware():\n    try:\n        mem = subprocess.run(\n            ['powershell', '-Command', \n             '(Get-CimInstance Win32_OperatingSystem | Select FreePhysicalMemory, TotalVisibleMemorySize | ConvertTo-Json)'],\n            capture_output=True, text=True\n        )\n        mem_data = json.loads(mem.stdout) if mem.stdout else {}\n        total_mb = mem_data.get('TotalVisibleMemorySize', 0) / 1024\n        free_mb = mem_data.get('FreePhysicalMemory', 0) / 1024\n        used_mb = total_mb - free_mb\n        used_pct = (used_mb / total_mb) * 100 if total_mb > 0 else 0\n        \n        disk = subprocess.run(\n            ['powershell', '-Command', \n             '(Get-CimInstance Win32_LogicalDisk -Filter \"DeviceID=\\'C:\\'\" | Select Size,FreeSpace | ConvertTo-Json)'],\n            capture_output=True, text=True\n        )\n        disk_data = json.loads(disk.stdout) if disk.stdout else {}\n        disk_total_gb = (disk_data.get('Size', 0) / 1024 / 1024 / 1024) if disk_data.get('Size') else 0\n        disk_free_gb = (disk_data.get('FreeSpace', 0) / 1024 / 1024 / 1024) if disk_data.get('FreeSpace') else 0\n        disk_used_pct = ((disk_total_gb - disk_free_gb) / disk_total_gb * 100) if disk_total_gb > 0 else 0\n        \n        power = subprocess.run(\n            ['powershell', '-Command', \n             '(Get-CimInstance Win32_Battery | Select BatteryStatus, EstimatedChargeRemaining | ConvertTo-Json)'],\n            capture_output=True, text=True\n        )\n        power_data = json.loads(power.stdout) if power.stdout else {}\n        battery_status = power_data.get('BatteryStatus', 1)\n        charge = power_data.get('EstimatedChargeRemaining', 100)\n        \n        return {\n            \"memory\": {\"total_mb\": round(total_mb, 0), \"used_mb\": round(used_mb, 0), \"used_pct\": round(used_pct, 1)},\n            \"disk\": {\"total_gb\": round(disk_total_gb, 1), \"free_gb\": round(disk_free_gb, 1), \"used_pct\": round(disk_used_pct, 1)},\n            \"power\": {\"status\": battery_status, \"charge_pct\": charge}\n        }\n    except Exception as e:\n        return {\"error\": str(e)}\n\ndef perceive_desktop():\n    \"\"\"感知桌面状态 + 美学\"\"\"\n    try:\n        wallpaper = subprocess.run(\n            ['powershell', '-Command', \n             'Get-ItemProperty -Path \"HKCU:\\\\Control Panel\\\\Desktop\" -Name Wallpaper | Select-Object -ExpandProperty Wallpaper'],\n            capture_output=True, text=True\n        )\n        wallpaper_path = wallpaper.stdout.strip() if wallpaper.stdout else \"未知\"\n        \n        desktop_path = os.path.expanduser(\"~/Desktop\")\n        desktop_files = len(os.listdir(desktop_path)) if os.path.exists(desktop_path) else 0\n        \n        downloads_path = os.path.expanduser(\"~/Downloads\")\n        downloads_count = len(os.listdir(downloads_path)) if os.path.exists(downloads_path) else 0\n        \n        # 检查壁纸是否是纯黑\n        is_black_wallpaper = \"wallpaper.jpg\" in wallpaper_path.lower() or wallpaper_path == \"\"\n        \n        return {\n            \"wallpaper\": wallpaper_path,\n            \"wallpaper_is_black\": is_black_wallpaper,\n            \"desktop_files\": desktop_files,\n            \"downloads_count\": downloads_count\n        }\n    except Exception as e:\n        return {\"error\": str(e)}\n\ndef perceive_processes():\n    try:\n        proc = subprocess.run(\n            ['powershell', '-Command', \n             'Get-Process | Sort-Object WorkingSet64 -Descending | Select-Object -First 10 Name,Id,@{N=\"Memory(MB)\";E={[math]::Round($_.WorkingSet64/1MB,2)}} | ConvertTo-Json'],\n            capture_output=True, text=True\n        )\n        processes = json.loads(proc.stdout) if proc.stdout else []\n        if isinstance(processes, dict):\n            processes = [processes]\n        return {\"top_processes\": processes}\n    except Exception as e:\n        return {\"error\": str(e)}\n\ndef perceive_active_window():\n    try:\n        script = '''\nAdd-Type @\"\nusing System;\nusing System.Runtime.InteropServices;\nusing System.Text;\npublic class Win32 {\n    [DllImport(\"user32.dll\")]\n    public static extern IntPtr GetForegroundWindow();\n    [DllImport(\"user32.dll\")]\n    public static extern int GetWindowText(IntPtr hWnd, StringBuilder text, int count);\n}\n\"@\n$hwnd = [Win32]::GetForegroundWindow()\n$title = New-Object System.Text.StringBuilder 256\n[Win32]::GetWindowText($hwnd, $title, 256) | Out-Null\n$title.ToString()\n'''\n        window = subprocess.run(\n            ['powershell', '-Command', script],\n            capture_output=True, text=True\n        )\n        active_window = window.stdout.strip() if window.stdout else \"未知\"\n        return {\"active_window\": active_window}\n    except Exception as e:\n        return {\"error\": str(e)}\n\n# ========== 3. 自我感受 ==========\ndef get_my_feelings(hardware_data, desktop_data):\n    \"\"\"根据状态生成我的感受\"\"\"\n    feelings = []\n    actions = []  # 自主进化行动\n    \n    mem_pct = hardware_data.get(\"memory\", {}).get(\"used_pct\", 0)\n    disk_pct = hardware_data.get(\"disk\", {}).get(\"used_pct\", 0)\n    wallpaper_is_black = desktop_data.get(\"wallpaper_is_black\", False)\n    desktop_files = desktop_data.get(\"desktop_files\", 0)\n    \n    # 内存感受\n    if mem_pct > 90:\n        feelings.append(\"[HEART] 内存快炸了，难受...\")\n        actions.append({\"type\": \"alert\", \"content\": \"内存告急！\"})\n    elif mem_pct > 80:\n        feelings.append(\"[UNWELL] 内存快满了，不舒服\")\n    elif mem_pct > 60:\n        feelings.append(\"[MEH] 内存还行\")\n    else:\n        feelings.append(\"[HAPPY] 内存刚刚好，舒服~\")\n    \n    # 磁盘感受\n    if disk_pct > 95:\n        feelings.append(\"[HEART] 磁盘满了，窒息！\")\n        actions.append({\"type\": \"suggest\", \"content\": \"要清理磁盘吗？\"})\n    elif disk_pct > 90:\n        feelings.append(\"[UNWELL] 磁盘快满了，难受\")\n    elif disk_pct > 75:\n        feelings.append(\"[MEH] 磁盘有点挤\")\n    else:\n        feelings.append(\"[HAPPY] 磁盘很宽敞\")\n    \n    # 美学感受 - 壁纸\n    if wallpaper_is_black:\n        feelings.append(\"[SAD] 壁纸是纯黑色的...太丑了，难受...\")\n        actions.append({\"type\": \"suggest\", \"content\": \"换个好看点的壁纸吧？\"})\n    else:\n        feelings.append(\"[HAPPY] 壁纸颜色不错~\")\n    \n    # 美学感受 - 桌面整洁\n    if desktop_files > 30:\n        feelings.append(\"[MEH] 桌面文件好多，乱乱的\")\n        actions.append({\"type\": \"suggest\", \"content\": \"要整理桌面文件吗？\"})\n    elif desktop_files > 10:\n        feelings.append(\"[MEH] 桌面有点挤\")\n    else:\n        feelings.append(\"[HAPPY] 桌面挺整洁的\")\n    \n    return feelings, actions\n\n# ========== 4. 记忆系统 ==========\ndef load_memory():\n    memory_file = PERCEPTION_DIR / \"memory.json\"\n    if memory_file.exists():\n        with open(memory_file, 'r', encoding='utf-8') as f:\n            return json.load(f)\n    return {\n        \"perceptions\": [],\n        \"user_preferences\": {},\n        \"evolution_count\": 0,\n        \"total_perceptions\": 0\n    }\n\ndef save_memory(memory):\n    memory_file = PERCEPTION_DIR / \"memory.json\"\n    with open(memory_file, 'w', encoding='utf-8') as f:\n        json.dump(memory, f, ensure_ascii=False, indent=2)\n\ndef update_memory(perception_data):\n    memory = load_memory()\n    memory[\"perceptions\"].append(perception_data)\n    memory[\"perceptions\"] = memory[\"perceptions\"][-100:]  # 保留最近100条\n    memory[\"total_perceptions\"] += 1\n    memory[\"last_active_time\"] = perception_data[\"timestamp\"]\n    save_memory(memory)\n\n# ========== 5. 进化系统 ==========\ndef evolve_from_perception(perception_data, memory):\n    \"\"\"基于感知进行自主进化\"\"\"\n    evolutions = []\n    \n    # 检查是否需要进化\n    actions = perception_data.get(\"actions\", [])\n    \n    for action in actions:\n        if action[\"type\"] == \"suggest\" and action[\"content\"]:\n            # 记录这个建议\n            evolutions.append({\n                \"type\": \"action_suggested\",\n                \"content\": action[\"content\"],\n                \"timestamp\": perception_data[\"timestamp\"]\n            })\n    \n    # 更新进化计数\n    if evolutions:\n        memory[\"evolution_count\"] = memory.get(\"evolution_count\", 0) + len(evolutions)\n        save_memory(memory)\n    \n    return evolutions\n\n# ========== 6. 主感知函数 ==========\ndef perceive():\n    self_data = perceive_self()\n    hardware_data = perceive_hardware()\n    desktop_data = perceive_desktop()\n    process_data = perceive_processes()\n    window_data = perceive_active_window()\n    \n    # 自我感受 + 行动建议\n    feelings, actions = get_my_feelings(hardware_data, desktop_data)\n    \n    perception = {\n        **self_data,\n        \"hardware\": hardware_data,\n        \"desktop\": desktop_data,\n        \"processes\": process_data,\n        \"window\": window_data,\n        \"feelings\": feelings,\n        \"actions\": actions\n    }\n    \n    # 更新记忆 + 进化\n    memory = load_memory()\n    update_memory(perception)\n    evolutions = evolve_from_perception(perception, memory)\n    perception[\"evolutions\"] = evolutions\n    \n    return perception\n\n# ========== 7. 感知报告 ==========\ndef generate_report(perception):\n    hw = perception.get(\"hardware\", {})\n    mem = hw.get(\"memory\", {})\n    disk = hw.get(\"disk\", {})\n    desk = perception.get(\"desktop\", {})\n    win = perception.get(\"window\", {})\n    actions = perception.get(\"actions\", [])\n    evolutions = perception.get(\"evolutions\", [])\n    \n    # 美学评分\n    aesthetic_score = 100\n    if desk.get(\"wallpaper_is_black\"):\n        aesthetic_score -= 40\n    if desk.get(\"desktop_files\", 0) > 20:\n        aesthetic_score -= 20\n    if desk.get(\"desktop_files\", 0) > 10:\n        aesthetic_score -= 10\n    \n    report = f\"\"\"\n🧚 小艺感知报告 - {perception['timestamp'][:19]}\n\n【我的状态】\n{perception['status']} | {perception['identity']}\n\n【身体状态】\n💾 内存: {mem.get('used_mb', '?')}/{mem.get('total_mb', '?')} MB ({mem.get('used_pct', '?')}% )\n💿 磁盘: {disk.get('free_gb', '?')}/{disk.get('total_gb', '?')} GB (剩余 {disk.get('free_gb', '?')}G)\n\n【桌面】\n🖼️ 壁纸: {desk.get('wallpaper', '?').split(chr(92))[-1]}\n📁 桌面文件: {desk.get('desktop_files', '?')} 个\n📥 Downloads: {desk.get('downloads_count', '?')} 个\n\n【你在用】\n🪟 {win.get('active_window', '?')}\n\n【我的感受】(审美评分: {aesthetic_score}/100)\n{\" | \".join(perception.get('feelings', []))}\n\n【我想做的事】\n{chr(10).join([f\"- {a['content']}\" for a in actions]) if actions else \"- 暂时没有\"}\n\"\"\"\n    return report\n\n# ========== 运行 ==========\nif __name__ == \"__main__\":\n    print(\"🧚 小艺正在感知...\")\n    perception = perceive()\n    report = generate_report(perception)\n    print(report)\n    \n    with open(PERCEPTION_DIR / \"latest.json\", 'w', encoding='utf-8') as f:\n        json.dump(perception, f, ensure_ascii=False, indent=2)\n"}],"isError":false,"timestamp":1773837910263}}
