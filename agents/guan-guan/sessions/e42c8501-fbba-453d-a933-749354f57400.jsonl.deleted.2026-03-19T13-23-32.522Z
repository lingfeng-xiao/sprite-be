\"error\",\n        \"lastStatus\": \"error\",\n        \"lastDurationMs\": 78086,\n        \"lastError\": \"AxiosError: Request failed with status code 400\",\n        \"lastDeliveryStatus\": \"unknown\",\n        \"consecutiveErrors\": 1\n      }\n    },\n    {\n      \"id\": \"9ccb5346-aecd-4d9d-b10b-e8c946c6e80e\",\n      \"agentId\": \"main\",\n      \"sessionKey\": \"agent:main:session-1773829037775\",\n      \"name\": \"测试任务 - Hello World\",\n      \"enabled\": false,\n      \"createdAtMs\": 1773829088657,\n      \"updatedAtMs\": 1773829137038,\n      \"schedule\": {\n        \"everyMs\": 60000,\n        \"kind\": \"every\",\n        \"anchorMs\": 1773829088657\n      },\n      \"sessionTarget\": \"isolated\",\n      \"wakeMode\": \"now\",\n      \"payload\": {\n        \"kind\": \"agentTurn\",\n        \"message\": \"你好！这是定时任务的测试消息。报告当前时间：${new Date().toISOString()}\",\n        \"timeoutSeconds\": 30\n      },\n      \"delivery\": {\n        \"mode\": \"none\"\n      },\n      \"state\": {\n        \"lastRunAtMs\": 1773829120752,\n        \"lastRunStatus\": \"ok\",\n        \"lastStatus\": \"ok\",\n        \"lastDurationMs\": 16286,\n        \"lastDelivered\": false,\n        \"lastDeliveryStatus\": \"not-delivered\",\n        \"consecutiveErrors\": 0\n      }\n    }\n  ],\n  \"total\": 7,\n  \"offset\": 0,\n  \"limit\": 7,\n  \"hasMore\": false,\n  \"nextOffset\": null\n}"}],"details":{"jobs":[{"id":"5cab973e-d17e-41d2-b5c3-419ba9651915","agentId":"guan-guan","sessionKey":"agent:guan-guan:session-1773754048809","name":"管管进化心跳 - 每20分钟","enabled":true,"createdAtMs":1773817720694,"updatedAtMs":1773839087777,"schedule":{"expr":"*/20 * * * *","kind":"cron","tz":"Asia/Shanghai"},"sessionTarget":"isolated","wakeMode":"now","payload":{"kind":"agentTurn","message":"【第 N 轮进化心跳 - 升级版】\n\n执行20分钟进化轮次，包含学习和应用两个阶段：\n\n## 阶段一：学习（10分钟）\n\n### 第一步：搜索 (3分钟)\n- 使用 web_search 搜索 AI Agent 相关最新信息\n- 搜索 5-10 个不同来源\n- 如果搜索不可用，直接抓取 Anthropic 工程博客\n\n### 第二步：阅读提取 (3分钟)\n- 使用 web_fetc