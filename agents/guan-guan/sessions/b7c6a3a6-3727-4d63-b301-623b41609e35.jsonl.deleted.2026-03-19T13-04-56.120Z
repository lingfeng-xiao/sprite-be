 2小时汇总】\\n\\n执行完整进化检查并生成汇总报告：\\n\\n1. 统计知识库当前数量\\n2. 梳理本周期学习内容\\n3. 生成汇总报告格式：\\n\\n---\\n## 📊 进化报表 - {时间}\\n\\n### 学习成果\\n- 学习篇数：X\\n- 主要内容：技术/审美/工具/人格/认知/社交\\n- 新技能：\\n\\n### 方案优化\\n- 调整内容：\\n- 优化建议：\\n\\n### 下一步计划\\n-\\n---\\n\\n（每2小时执行一次，详细汇报）\",\n        \"timeoutSeconds\": 300\n      },\n      \"delivery\": {\n        \"channel\": \"webchat\",\n        \"mode\": \"announce\",\n        \"to\": \"gateway-client\"\n      },\n      \"state\": {\n        \"lastRunAtMs\": 1773821265251,\n        \"lastRunStatus\": \"error\",\n        \"lastStatus\": \"error\",\n        \"lastDurationMs\": 78086,\n        \"lastError\": \"AxiosError: Request failed with status code 400\",\n        \"lastDeliveryStatus\": \"unknown\",\n        \"consecutiveErrors\": 1\n      }\n    },\n    {\n      \"id\": \"9ccb5346-aecd-4d9d-b10b-e8c946c6e80e\",\n      \"agentId\": \"main\",\n      \"sessionKey\": \"agent:main:session-1773829037775\",\n      \"name\": \"测试任务 - Hello World\",\n      \"enabled\": false,\n      \"createdAtMs\": 1773829088657,\n      \"updatedAtMs\": 1773829137038,\n      \"schedule\": {\n        \"everyMs\": 60000,\n        \"kind\": \"every\",\n        \"anchorMs\": 1773829088657\n      },\n      \"sessionTarget\": \"isolated\",\n      \"wakeMode\": \"now\",\n      \"payload\": {\n        \"kind\": \"agentTurn\",\n        \"message\": \"你好！这是定时任务的测试消息。报告当前时间：${new Date().toISOString()}\",\n        \"timeoutSeconds\": 30\n      },\n      \"delivery\": {\n        \"mode\": \"none\"\n      },\n      \"state\": {\n        \"lastRunAtMs\": 1773829120752,\n        \"lastRunStatus\": \"ok\",\n        \"lastStatus\": \"ok\",\n        \"lastDurationMs\": 16286,\n        \"lastDelivered\": false,\n        \"lastDeliveryStatus\": \"not-delivered\",\n        \"consecutiveErrors\": 0\n      }\n    }\n  ],\n  \"total\": 10,\n  \"offset\": 0,\n  \"limit\": 10,\n  \"hasMore\": false,\n  \"nextOffset\": null\n}"}],"details":{"jobs":[{"id":"1bd98a83-e6f0-432f-a1dc-814bf60a601e","agentId