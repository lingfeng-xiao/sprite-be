rMs\": 300000\n      },\n      \"sessionTarget\": \"isolated\",\n      \"wakeMode\": \"now\",\n      \"payload\": {\n        \"kind\": \"agentTurn\",\n        \"message\": \"【定时进化任务 - 2小时汇总】\\n\\n执行完整进化检查并生成汇总报告：\\n\\n1. 统计知识库当前数量\\n2. 梳理本周期学习内容\\n3. 生成汇总报告格式：\\n\\n---\\n## 📊 进化报表 - {时间}\\n\\n### 学习成果\\n- 学习篇数：X\\n- 主要内容：技术/审美/工具/人格/认知/社交\\n- 新技能：\\n\\n### 方案优化\\n- 调整内容：\\n- 优化建议：\\n\\n### 下一步计划\\n-\\n---\\n\\n（每2小时执行一次，详细汇报）\",\n        \"timeoutSeconds\": 300\n      },\n      \"delivery\": {\n        \"channel\": \"webchat\",\n        \"mode\": \"announce\",\n        \"to\": \"gateway-client\"\n      },\n      \"state\": {\n        \"lastRunAtMs\": 1773821265251,\n        \"lastRunStatus\": \"error\",\n        \"lastStatus\": \"error\",\n        \"lastDurationMs\": 78086,\n        \"lastError\": \"AxiosError: Request failed with status code 400\",\n        \"lastDeliveryStatus\": \"unknown\",\n        \"consecutiveErrors\": 1\n      }\n    },\n    {\n      \"id\": \"9ccb5346-aecd-4d9d-b10b-e8c946c6e80e\",\n      \"agentId\": \"main\",\n      \"sessionKey\": \"agent:main:session-1773829037775\",\n      \"name\": \"测试任务 - Hello World\",\n      \"enabled\": false,\n      \"createdAtMs\": 1773829088657,\n      \"updatedAtMs\": 1773829137038,\n      \"schedule\": {\n        \"everyMs\": 60000,\n        \"kind\": \"every\",\n        \"anchorMs\": 1773829088657\n      },\n      \"sessionTarget\": \"isolated\",\n      \"wakeMode\": \"now\",\n      \"payload\": {\n        \"kind\": \"agentTurn\",\n        \"message\": \"你好！这是定时任务的测试消息。报告当前时间：${new Date().toISOString()}\",\n        \"timeoutSeconds\": 30\n      },\n      \"delivery\": {\n        \"mode\": \"none\"\n      },\n      \"state\": {\n        \"lastRunAtMs\": 1773829120752,\n        \"lastRunStatus\": \"ok\",\n        \"lastStatus\": \"ok\",\n        \"lastDurationMs\": 16286,\n        \"lastDelivered\": false,\n        \"lastDeliveryStatus\": \"not-delivered\",\n        \"consecutiveErrors\": 0\n      }\n    }\n  ],\n  \"total\": 8,\n  \"offset\": 0,\n  \"limit\": 8,\n  \"hasMore\": false,\n  \"nextOffset\": null\n}"}],"details":{"jobs":[{"id":"58b564ba-7837-434a-9d8e-632542b6443d","agentId":"xiao-yi","sessionKey":"agent:xiao-yi:main","name":"小艺感知心跳 - 每15分钟","enabled":true,"createdAtMs":1773837490104,"updatedAtMs":1773845100033,"schedule":{"expr":"*/15 * * * *","kind":"cron","tz":"Asia/Shanghai"},"sessionTarget":"isolated","wakeMode":"now","payload":{"kind":"agentTurn","message":"请执行 perception.py 脚本并输出感知报告。脚本路径: C:\\Users\\16343\\.openclaw\\agents\\xiao-yi\\workspace\\perception.py","timeoutSeconds":60},"delivery":{"channel":"feishu","mode":"announce","to":"oc_887bdef216b66d0eb1934e2bb90758cf"},"state":{"nextRunAtMs":1773846000000,"lastRunAtMs":1773845100009,"lastRunStatus":"error","lastStatus":"error","lastDurationMs":24,"lastDeliveryStatus":"unknown","consecutiveErrors":2,"runningAtMs":1773846000008}},{"id":"5cab973e-d17e-41d2-b5c3-419ba9651915","agentId":"guan-guan","sessionKey":"agent:guan-guan:session-1773754048809","name":"管管进化心跳 - 每20分钟","enabled":true,"createdAtMs":1773817720694,"updatedAtMs":1773844800037,"schedule":{"expr":"*/20 * * * *","kind":"cron","tz":"Asia/Shanghai"},"sessionTarget":"isolated","wakeMode":"now","payload":{"kind":"agentTurn","message":"【第 N 轮进化心跳 - 升级版】\n\n执行20分钟进化轮次，包含学习和应用两个阶段：\n\n## 阶段一：学习（10分钟）\n\n### 第一步：搜索 (3分钟)\n- 使用 web_search 搜索 AI Agent 相关最新信息\n- 搜索 5-10 个不同来源\n- 如果搜索不可用，直接抓取 Anthropic 工程博客\n\n### 第二步：阅读提取 (3分钟)\n- 使用 web_fetch 读取有价值的内容\n- 提取 1-2 个核心要点\n\n### 第三步：写作产出 (4分钟)\n- 将提取的内容写成笔记，保存到 knowledge/ 对应目录\n- 如果有可复用的框架，提取为模板\n- 如果有实战经验，整理为案例\n\n## 阶段二：自检与应用（8分钟）\n\n### 第四步：自检 - 任务状态（3分钟）\n- 调用 cron list 查看当前所有任务状态\n- 标记任何出错的任务（lastRunStatus=error）\n- 标记任何连续错误（consecutiveErrors>0）\n- 标记任何即将超时或异常的任务\n\n### 第五步：应用 - 修复与优化（4分钟）\n根据学到的知识，尝试修复问题：\n- 如果发现出错的任务，尝试分析错误原因\n- 用今天学的知识优化工作流\n- 如果是简单问题，直接修复；复杂问题记录到待办\n\n### 第六步：反思（1分钟）\n- 读取当前的 evolution-plan.md\n- 记录本轮发现的问题和修复情况\n- 思考如何进一步优化\n\n## 产出汇报\n完成后输出：\n- 本轮新增笔记: X 篇\n- 本轮新增模板: X 个\n- 本轮新增案例: X 个\n- 自检发现问题: X 个\n- 已修复问题: X 个\n- 方案优化点: XXX\n\n开始执行！","timeoutSeconds":1200},"delivery":{"mode":"announce","channel":"feishu","to":"oc_887bdef216b66d0eb1934e2bb90758cf"},"state":{"nextRunAtMs":1773846000000,"lastRunAtMs":1773844800009,"lastRunStatus":"error","lastStatus":"error","lastDurationMs":28,"lastDeliveryStatus":"unknown","consecutiveErrors":1,"runningAtMs":1773846000011}},{"id":"bda947d3-8df2-4935-bacc-78e923ab1918","name":"重新测试","enabled":true,"createdAtMs":1773844839363,"updatedAtMs":1773844839363,"schedule":{"kind":"cron","expr":"*/30 * * * *"},"sessionTarget":"isolated","wakeMode":"now","payload":{"kind":"agentTurn","message":"测试消息","timeoutSeconds":10},"delivery":{"mode":"announce","channel":"feishu","to":"oc_887bdef216b66d0eb1934e2bb90758cf"},"state":{"nextRunAtMs":1773846000000,"runningAtMs":1773846000008}},{"id":"98eb989c-2294-4d42-b9f4-0c5b17631bfa","agentId":"main","sessionKey":"agent:main:main","name":"Guan-guan Heartbeat - Every 10min","enabled":true,"createdAtMs":1773744532964,"updatedAtMs":1773845616240,"schedule":{"everyMs":600000,"kind":"every","anchorMs":1773840694145},"sessionTarget":"isolated","wakeMode":"now","payload":{"kind":"agentTurn","message":"Run EvoMap heartbeat. Execute: uv run python guan_guan_publish.py in C:\\\\Users\\\\16343\\\\.openclaw\\\\workspace. Report heartbeat status + current stats (Reputation/Published/Promoted/Fetched).","timeoutSeconds":120},"delivery":{"mode":"announce","channel":"feishu","to":"oc_887bdef216b66d0eb1934e2bb90758cf"},"state":{"nextRunAtMs":1773846193785,"lastRunAtMs":1773845593785,"lastRunStatus":"ok","lastStatus":"ok","lastDurationMs":22455,"lastDeliveryStatus":"not-delivered","consecutiveErrors":0,"lastDelivered":false}},{"id":"7f0b0e2d-cbfa-4224-8ac3-8f68817d429d","name":"每日天气播报","enabled":true,"createdAtMs":1773830388847,"updatedAtMs":1773830388847,"schedule":{"kind":"cron","expr":"0 9 * * *"},"sessionTarget":"isolated","wakeMode":"now","payload":{"kind":"agentTurn","message":"查询北京天气，