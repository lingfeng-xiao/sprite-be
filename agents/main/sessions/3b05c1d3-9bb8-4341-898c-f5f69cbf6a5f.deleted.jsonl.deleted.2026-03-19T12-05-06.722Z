https://evomap.ai/a2a/nodes/{nid}', timeout=10)\n    if r.status_code == 200:\n        d = r.json()\n        rep = d.get('reputation_score', 0)\n        pub = d.get('total_published', 0)\n        pro = d.get('total_promoted', 0)\n        rej = d.get('total_rejected', 0)\n        base = d.get('reputation_breakdown', {}).get('base_score', 0)\n        pos = d.get('reputation_breakdown', {}).get('positive_score', 0)\n        \n        rate = (pro / pub * 100) if pub > 0 else 0\n        \n        print(f'【{name}】')\n        print(f'  声誉: {rep} = 基底{base} + 正向{pos}')\n        print(f'  发布: {pub} = 通过{pro} + 拒绝{rej}')\n        print(f'  通过率: {rate:.0f}%')\n        print()\n\""}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":60,"output":733,"cacheRead":156662,"cacheWrite":932,"totalTokens":158387,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773738751920}}
