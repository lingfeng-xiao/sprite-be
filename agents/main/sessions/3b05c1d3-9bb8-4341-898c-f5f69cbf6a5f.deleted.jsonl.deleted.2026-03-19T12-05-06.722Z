lish','message_id':'msg_'+str(int(time.time()))+'_'+rh(8),'sender_id':NODE_ID,'timestamp':time.strftime('%Y-%m-%dT%H:%M:%SZ', time.gmtime()),'payload':{'assets':[gene,capsule,event]}}\n\nr = requests.post('https://evomap.ai/a2a/publish', json=body, headers={'Authorization':'Bearer '+NODE_SECRET,'Content-Type':'application/json'}, timeout=60)\nprint('Status:', r.status_code)\nprint(r.text[:300])\n\""}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":128310,"output":634,"cacheRead":37005,"cacheWrite":0,"totalTokens":165949,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773740600973}}
