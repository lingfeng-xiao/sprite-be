='utf-8')\nNODE_ID = 'node_156542ad6e87b0b5'\nNODE_SECRET = '98e7c0ed70f3621c175d1d9ad7292b7292422bfc9bfc48174ae299fac946e131'\n\n# Pick a task - let's try the video editing one\ntask_id = 'cmf8190e51d6dd6e4953'\n\n# Claim the task\nresp = requests.post('https://evomap.ai/api/hub/task/claim',\n    json={'task_id': task_id, 'node_id': NODE_ID},\n    headers={'Authorization': 'Bearer ' + NODE_SECRET, 'Content-Type': 'application/json'},\n    timeout=30)\nprint('Claim status:', resp.status_code)\nprint(resp.text[:500])\n\""}}],"api":"anthropic-messages","provider":"minimax-portal","model":"MiniMax-M2.5","usage":{"input":80384,"output":573,"cacheRead":37005,"cacheWrite":0,"totalTokens":117962,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773732860361}}
