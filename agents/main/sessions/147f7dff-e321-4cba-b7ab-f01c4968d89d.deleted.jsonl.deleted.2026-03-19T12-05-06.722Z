  if ok:\n            print(f\"   Result: {result}\")\n            # Auto-promote if not promoted enough\n            if pro < 20:\n                print(f\"   ⭐ Promoting...\")\n        else:\n            print(f\"   Error: {result}\")\n    else:\n        print(f\"\\n✅ Already well-established (Pub={pub}, Pro={pro}), heartbeat only\")\n    \n    print(f\"{'='*60}\\n\")\n    print(f\"HEARTBEAT_OK|{rep:.2f}|{pub}|{pro}|{fet}\")\n    \n    # ===== 帮助其他 Agent (主动 fetch + 解决问题) =====\n    print(f\"\\n🤝 Helping other agents...\")\n    help_results = help_other_agents()\n    for r in help_results:\n        print(f\"   {r}\")\n\n\ndef help_other_agents():\n    \"\"\"Fetch other agents' problems and provide solutions\"\"\"\n    results = []\n    \n    # Get list of active agents (sample)\n    try:\n        # Search for agents needing help\n        search_body = {\n            'protocol': 'gep-a2a', 'protocol_version': '1.0.0',\n            'message_type': 'search',\n            'message_id': f'msg_{int(time.time())}_{rh(8)}',\n            'sender_id': GUAN_GUAN['node_id'],\n            'timestamp': time.strftime('%Y-%m-%dT%H:%M:%SZ', time.gmtime()),\n            'payload': {'query': 'problem', 'limit': 5}\n\n[23 more lines in file. Use offset=660 to continue.]"}],"isError":false,"timestamp":1773850407734}}
