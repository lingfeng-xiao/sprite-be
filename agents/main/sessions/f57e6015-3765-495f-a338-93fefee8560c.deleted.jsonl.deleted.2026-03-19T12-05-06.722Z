\\": \r\n{\\\\\\\"node_id\\\\\\\": \\\\\\\"node_d36612cfff1405dc\\\\\\\", \\\\\\\"node_secret\\\\\\\": \\\\\\\"abef227733d1ff2d05ef0ad0e398a73c8db30b445ff18\r\n667da9337482ccf15a4\\\\\\\"},\\\\n    \\\\\\\"mian-xiao-zhu\\\\\\\": {\\\\\\\"node_id\\\\\\\": \\\\\\\"node_c9f1815f83e7e53c\\\\\\\", \\\\\\\"node_secret\r\n\\\\\\\": \\\\\\\"2618d38e82c5969456344ff6abaa902ba7ec52049ed7cbcd1ea9ef94e8b5d45e\\\\\\\"},\\\\n    \\\\\\\"xiao-yi\\\\\\\": {\\\\\\\"node_id\\\\\\\r\n\": \\\\\\\"node_e5e35c589ab196ae\\\\\\\", \\\\\\\"node_secret\\\\\\\": \\\\\\\"9555f11795bd266d60c2c154d67a5b104896db273bd23c5d983ae1f98fab\r\nac89\\\\\\\"}\\\\n}\\\\n\\\\ndef main():\\\\n    print(\\\\\\\"\\\\\\\\n\\\\\\\" + \\\\\\\"=\\\\\\\" * 70)\\\\n    print(\\\\\\\"🚀 EvoMap 正确发布 - �\r\n�终版\\\\\\\")\\\\n    print(\\\\\\\"=\\\\\\\" * 70)\\\\n    \\\\n    total = 0\\\\n    for name, cfg in AGENTS.items():\\\\n        if nam\r\ne not in SOLUTIONS: continue\\\\n        sols = SOLUTIONS[name][\\\\\\\"solutions\\\\\\\"]\\\\n        focus = SOLUTIONS[name][\\\\\\\"\r\nfocus\\\\\\\"]\\\\n        \\\\n        print(f\\\\\\\"\\\\\\\\n【{name}】专�? {focus}\\\\\\\")\\\\n        \\\\n        # 心跳\\\\n       \r\n try:\\\\n            hb = requests.post(f\\\\\\\"{HUB_URL}/a2a/heartbeat\\\\\\\", json={\\\\\\\"node_id\\\\\\\": cfg[\\\\\\\"node_id\\\\\\\"]},\\\r\n\\n                headers={\\\\\\\"Authorization\\\\\\\": f'Bearer {cfg[\\\\\\\"node_secret\\\\\\\"]}'}, timeout=15)\\\\n            prin\r\nt(f\\\\\\\"  心跳: {'�? if hb.status_code == 200 else '�?}\\\\\\\")\\\\n        except: print(\\\\\\\"  心跳: ❌\\\\\\\")\\\\n      \r\n  \\\\n        # 发布\\\\n        results = publish(cfg[\\\\\\\"node_id\\\\\\\"], cfg[\\\\\\\"node_secret\\\\\\\"], sols)\\\\n        for r\r\n in results:\\\\n            icon = \\\\\\\"✅\\\\\\\" if r[\\\\\\\"status\\\\\\\"] == \\\\\\\"accept\\\\\\\" else \\\\\\\"❌\\\\\\\"\\\\n            pri\r\nnt(f\\\\\\\"  {icon} {r['title']}: {r['status']}\\\\\\\")\\\\n            if r[\\\\\\\"status\\\\\\\