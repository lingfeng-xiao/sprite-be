4 = New-Object System.Drawing.Point(1680, 850)\n$p5 = New-Object System.Drawing.Point(1710, 900)\n$p6 = New-Object System.Drawing.Point(1800, 780)\n$g.DrawLines($bluePen, @($p4, $p5, $p6))\n\n# 中间大圆\n$g.DrawEllipse($blackPen, 500, 400, 200, 200)\n$g.DrawEllipse($blackPen, 530, 430, 140, 140)\n$g.DrawEllipse($bluePen, 560, 460, 80, 80)\n\n# 中央星星\n$starPts2 = @()\n$cx2, $cy2 = 1000, 540\nfor ($i = 0; $i -lt 5; $i++) {\n    $a = [Math]::PI * 2 * $i / 5 - [Math]::PI / 2\n    $starPts2 += New-Object System.Drawing.Point([int]($cx2 + 50 * [Math]::Cos($a)), [int]($cy2 + 50 * [Math]::Sin($a)))\n    $a2 = $a + [Math]::PI / 5\n    $starPts2 += New-Object System.Drawing.Point([int]($cx2 + 22 * [Math]::Cos($a2)), [int]($cy2 + 22 * [Math]::Sin($a2)))\n}\n$starPts2 += $starPts2[0]\n$g.DrawLines($blackPen, $starPts2)\n\n# 底部线条\n$g.DrawLine($blackPen, 600, 900, 1100, 900)\n$g.DrawLine($bluePen, 700, 940, 1000, 940)\n$g.DrawLine($blackPen, 750, 980, 950, 980)\n\n# 保存 BMP\n$path = \"C:\\Users\\16343\\Desktop\\Notion-Theme\\wallpapers\\notion-doodle.bmp\"\n$bmp.Save($path, [System.Drawing.Imaging.ImageFormat]::Bmp)\n$g.Dispose()\n$bmp.Dispose()\n\nWrite-Host \"壁纸已创建: $path\"\n(Get-Item $path).Length"}}],"api":"openai-completions","provider":"siliconflow","model":"Pro/zai-org/GLM-5","usage":{"input":2054,"output":1207,"cacheRead":40960,"cacheWrite":0,"totalTokens":44221,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773638279851}}
